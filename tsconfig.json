{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "daemon/dist",
    "rootDir": ".",
    "declaration": false,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "typeRoots": ["daemon/node_modules/@types"]
  },
  "include": ["daemon/**/*.ts", "shared/**/*.ts", "script/**/*.ts"]
}
