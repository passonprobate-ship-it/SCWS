# === Dependencies ===
node_modules/

# === Environment / secrets ===
.env
.env.*
!.env.example

# === Build artifacts ===
# Ignore all dist/ except daemon/dist/ (daemon source not on Pi)
dist/
!daemon/dist/

# === Runtime / logs ===
logs/
*.log
backups/

# === OS / editor ===
.DS_Store
*.swp
*.swo
*~

# === Claude Code local state ===
.claude/

# === Backup / old builds ===
*.bak
*.pre-funnel
*.pre-opt

# === Instance manifest (per-machine, not committed) ===
.spawn-instance.json

# === Projects — user-created projects are not committed ===
projects/*
# Deployment tooling IS tracked (needed by installer)
!projects/spawn-vps/
!projects/spawn-pi/

# === Backup token (sourced by offsite script) ===
scripts/.backup-token
