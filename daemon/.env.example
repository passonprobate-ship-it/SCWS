# SPAWN Daemon Configuration
# Copy to .env and fill in your values: cp .env.example .env

# PostgreSQL connection string
DATABASE_URL=postgresql://scws:YOUR_DB_PASSWORD@localhost:5432/scws_daemon

# Daemon port (default: 4000)
PORT=4000

# Dashboard auth token — generate with: openssl rand -hex 32
DASHBOARD_TOKEN=

# PostgreSQL password for the scws user (must match DATABASE_URL)
SCWS_DB_PASSWORD=

# Base URL for this SPAWN instance (Tailscale IP, VPS IP, or domain)
SCWS_BASE_URL=http://YOUR_IP_OR_HOSTNAME

# Environment (production recommended)
NODE_ENV=production

# Encryption key for connection secrets — generate with: openssl rand -hex 32
ENCRYPTION_KEY=
